{
  "name": "zonot",
  "version": "0.0.0",
  "type": "module",
  "description": "Zonot CLI — calm capture, deep notes, plain Markdown in your own GitHub repo.",
  "license": "FSL-1.1-ALv2",
  "bin": {
    "zonot": "./src/index.ts"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test --pass-with-no-tests",
    "dev": "bun run ./src/index.ts",
    "build": "bun build ./src/index.ts --compile --outfile ./dist/zonot",
    "build:binary": "bun build ./src/index.ts --compile --outfile ./dist/zonot"
  },
  "dependencies": {
    "@zonot/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
