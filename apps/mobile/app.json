{
  "expo": {
    "name": "Zonot",
    "slug": "zonot",
    "scheme": "zonot",
    "version": "0.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.zonot.mobile"
    },
    "android": {
      "package": "app.zonot.mobile"
    },
    "plugins": [
      "./plugins/withPnpmPodfileFix",
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
