{
  "name": "zonot",
  "private": true,
  "version": "0.0.0",
  "description": "A clear place to drop your thinking, where everything you keep stays connected below the surface.",
  "license": "FSL-1.1-ALv2",
  "author": "Chris Horne <cdh612@gmail.com>",
  "type": "module",
  "packageManager": "pnpm@11.15.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "scripts": {
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "typecheck": "pnpm -r --parallel typecheck",
    "test": "pnpm -r --parallel test",
    "build": "pnpm -r --parallel build",
    "ci": "pnpm check && pnpm typecheck && pnpm test",
    "prepare": "lefthook install || true"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/bun": "^1.3.14",
    "lefthook": "^2.1.10",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "isomorphic-git": "^1.38.7"
  }
}
