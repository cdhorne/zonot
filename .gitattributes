# Normalize line endings — LF everywhere except Windows-native shells
* text=auto eol=lf

*.{cmd,bat,ps1} text eol=crlf

# Binaries
*.{png,jpg,jpeg,gif,ico,webp,avif} binary
*.{woff,woff2,ttf,eot,otf} binary
*.{zip,gz,tgz,xz,7z} binary
*.{mp3,mp4,wav,webm,mov} binary

# Lockfiles — collapse diffs
pnpm-lock.yaml linguist-generated=true merge=ours

